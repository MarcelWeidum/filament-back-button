{
    "name": "marcelweidum/filament-back-button",
    "description": "Brings a back button to a resource view/edit page",
    "keywords": [
        "MarcelWeidum",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-back-button"
    ],
    "homepage": "https://github.com/marcelweidum/filament-back-button",
    "support": {
        "issues": "https://github.com/marcelweidum/filament-back-button/issues",
        "source": "https://github.com/marcelweidum/filament-back-button"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "MarcelWeidum",
            "email": "marcelweidum@live.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^v4.11||^v5.6",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "MarcelWeidum\\BackButton\\": "src/",
            "MarcelWeidum\\BackButton\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarcelWeidum\\BackButton\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MarcelWeidum\\BackButton\\BackButtonServiceProvider"
            ],
            "aliases": {
                "BackButton": "MarcelWeidum\\BackButton\\Facades\\BackButton"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
